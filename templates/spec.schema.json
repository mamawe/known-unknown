{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KnownUnknownSpec",
  "description": "JSON Schema for a structured requirement specification with knowns and unknowns",
  "type": "object",
  "required": [
    "slug",
    "meta",
    "intake",
    "items"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "description": "Unique identifier slug for this requirement scan"
    },
    "meta": {
      "type": "object",
      "required": [
        "scanned_at",
        "repository",
        "branch",
        "scanner_version"
      ],
      "properties": {
        "scanned_at": {
          "type": "string",
          "format": "date-time"
        },
        "repository": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "scanner_version": {
          "type": "string",
          "default": "2.0.0"
        }
      }
    },
    "intake": {
      "type": "object",
      "required": [
        "original_request",
        "scope_boundary",
        "core_objectives"
      ],
      "properties": {
        "original_request": {
          "type": "string",
          "description": "The original user prompt or requirement description"
        },
        "scope_boundary": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Explicit boundaries of what is IN scope and OUT of scope"
        },
        "core_objectives": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Success criteria / goals"
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "quadrant",
          "dimension",
          "statement",
          "evidence",
          "risk",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^U-[0-9]{3}$"
          },
          "quadrant": {
            "type": "string",
            "enum": [
              "known_known",
              "known_unknown",
              "unknown_known",
              "unknown_unknown"
            ]
          },
          "dimension": {
            "type": "string",
            "enum": [
              "D01_data_model",
              "D02_boundaries",
              "D03_error_handling",
              "D04_concurrency",
              "D05_performance",
              "D06_security_privacy",
              "D07_observability",
              "D08_testing",
              "D09_dependencies",
              "D10_ops_deploy",
              "D11_conventions",
              "D12_historical"
            ]
          },
          "statement": {
            "type": "string",
            "description": "The exact unknown or known fact described clearly"
          },
          "evidence": {
            "type": "object",
            "required": [
              "sources",
              "reasoning"
            ],
            "properties": {
              "sources": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "File paths, lines, or commit hashes supporting this item"
              },
              "reasoning": {
                "type": "string",
                "description": "Agent analysis and evidence of why this is a risk/blindspot"
              }
            }
          },
          "risk": {
            "type": "object",
            "required": [
              "impact",
              "likelihood",
              "reversibility",
              "score"
            ],
            "properties": {
              "impact": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high",
                  "critical"
                ]
              },
              "likelihood": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              "reversibility": {
                "type": "string",
                "enum": [
                  "easy",
                  "hard",
                  "irreversible"
                ]
              },
              "score": {
                "type": "number",
                "description": "Calculated risk score based on rubric metrics"
              }
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "answered",
              "deferred",
              "obsolete"
            ],
            "default": "open"
          },
          "answer": {
            "type": "string",
            "description": "User's clarification or answer to the unknown"
          },
          "answered_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
